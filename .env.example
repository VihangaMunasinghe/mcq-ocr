# Compose-time configuration. Copy to .env and fill in.
# `docker compose` reads this file automatically from the project root.
# Variables here are used for ${VAR} substitution inside docker-compose.yml itself.

# === Docker Registry & Image Tagging ===
DOCKER_REGISTRY=CHANGEME-dockerhub-username
IMAGE_TAG=latest

# === Domain (used by nginx envsubst) ===
DOMAIN_NAME=CHANGEME.example.com

# === Postgres (root values; the backend app also needs these in .env.app) ===
POSTGRES_DB=edumark_database
POSTGRES_USER=edumark_user
POSTGRES_PASSWORD=CHANGEME-strong-password
POSTGRES_PORT=5432

# === RabbitMQ (root values; the backend app also needs these in .env.app) ===
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGEME-rabbit-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
