# Application runtime configuration. Copy to .env.app and fill in.
# Mounted into backend and worker containers via `env_file:` in docker-compose.yml.
# Do NOT commit the filled .env.app — it contains secrets.

# === Database ===
# Values here MUST match POSTGRES_* in the root .env file.
DATABASE_URL=postgresql://edumark_user:CHANGEME-strong-password@postgres:5432/edumark_database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=edumark_database
DATABASE_USER=edumark_user
DATABASE_PASSWORD=CHANGEME-strong-password
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_RECYCLE=300
DATABASE_ECHO=false

# === Application ===
APP_NAME=Edumark
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
# Comma-separated list of allowed CORS origins (full origin with scheme).
ALLOWED_HOSTS=https://CHANGEME.example.com
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=uploads

# === Shared Storage ===
NFS_SHARED_PATH=/shared

# === RabbitMQ ===
# Values here MUST match RABBITMQ_* in the root .env file.
RABBITMQ_URL=amqp://admin:CHANGEME-rabbit-password@rabbitmq:5672
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGEME-rabbit-password

# === Queues (used by backend + workers; defaults below match existing code) ===
INDEX_TASK_QUEUE=index_tasks
INDEX_RESULTS_QUEUE=index_results
TEMPLATE_CONFIG_QUEUE=template_config_queue
MARKING_JOB_QUEUE=marking_job_queue
MARKING_CONFIG_QUEUE=marking_scheme_config_queue
MARKING_JOB_RESULTS_QUEUE=marking_job_results
TEMPLATE_CONFIG_RESULTS_QUEUE=template_config_results
MARKING_CONFIG_RESULTS_QUEUE=marking_scheme_config_results
# Index recognizer aliases for the same task/results queues
RABBITMQ_INCOMING_QUEUE=index_tasks
RABBITMQ_OUTGOING_QUEUE=index_results

# === Auth ===
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGEME-min-48-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SUPER_USER_EMAIL=CHANGEME@example.com
# Generate bcrypt hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash(input('pw: ')))"
SUPER_USER_PASSWORD=CHANGEME-bcrypt-hash

# === Cookies ===
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_HTTPONLY=true
