# Production Environment Configuration
# Copy this file to .env.prod and modify the values for your production environment

# Docker Registry Configuration
DOCKER_REGISTRY=your-dockerhub-username

# Database Configuration
POSTGRES_DB=mcq_database
POSTGRES_USER=mcq_user
POSTGRES_PASSWORD=your-secure-production-password
POSTGRES_PORT=5432

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your-secure-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Application Configuration
APP_NAME=MCQ OCR System
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Backend URL Configuration
BACKEND_URL=https://api.yourdomain.com

# Authentication & Security (CHANGE THESE!)
SECRET_KEY=your-super-secure-production-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SUPER_USER_EMAIL=admin@yourdomain.com
SUPER_USER_PASSWORD=$2a$12$your-hashed-production-password

# Cookie Security Settings
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_HTTPONLY=true

# Database Pool Settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_RECYCLE=300
DATABASE_ECHO=false
